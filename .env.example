# Copy thành .env và điền giá trị thật. Xem src/config.py.
DATABASE_URL=sqlite:///./data/app.db
CHROMA_PERSIST_DIR=./data/chroma
PROCEDURES_COLLECTION=tthc_procedures
BM25_INDEX_PATH=./data/bm25_index.json
# Ngưỡng nhận diện gồm confidence tương đối, relevance tuyệt đối và margin top-2.
# IDENTIFY_CONFIDENCE_THRESHOLD=0.55
# IDENTIFY_MIN_RELEVANCE=0.6
# IDENTIFY_MIN_MARGIN=0.15

# LLM: Claude (Anthropic) — model mặc định claude-haiku-4-5 (xem src/config.py).
# Điền API key Anthropic vào LLM_API_KEY (hoặc đặt ANTHROPIC_API_KEY).
# Thiếu key luồng chat vẫn chạy: planner/answer tự rơi về rule-based/extractive fallback.
LLM_PROVIDER=anthropic
LLM_API_KEY=
# LLM_MODEL=claude-haiku-4-5

# Embedding cho dense retrieval (auto | google | bge-m3 | fake) — phải khớp lúc index.
# 'google' cần GOOGLE_API_KEY riêng (không dùng chung với key Anthropic ở trên).
EMBEDDING_PROVIDER=auto
# GOOGLE_API_KEY=

OCR_ENGINE=paddleocr
OCR_CONFIDENCE_THRESHOLD=0.85
# GOOGLE_APPLICATION_CREDENTIALS=./secrets/gcp.json  # khi OCR_ENGINE=google_vision

READINESS_SUBMIT_THRESHOLD=0.9

JWT_SECRET=change-me
JWT_ACCESS_TTL_MINUTES=30
APP_ENV=development
ENABLE_DEMO_AUTH=true
DEMO_PASSWORD=change-me-local-only
PERSISTENCE_ENABLED=false
STORAGE_BACKEND=local
STORAGE_ROOT=./uploads/private
# Production OIDC settings (required when demo auth is disabled)
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_AUDIENCE=
OIDC_REDIRECT_URI=https://portal.example.gov.vn/api/v1/auth/oidc/callback
OIDC_REQUIRED_MFA_CLAIM=amr:mfa
UPLOAD_MAX_FILES=10
UPLOAD_MAX_BYTES=20971520
