# Copy thành .env và điền giá trị thật. Xem src/config.py.
DATABASE_URL=sqlite:///./data/app.db
CHROMA_PERSIST_DIR=./data/chroma
PROCEDURES_COLLECTION=tthc_procedures
BM25_INDEX_PATH=./data/bm25_index.json

LLM_PROVIDER=gemini
LLM_API_KEY=

OCR_ENGINE=paddleocr
OCR_CONFIDENCE_THRESHOLD=0.85
# GOOGLE_APPLICATION_CREDENTIALS=./secrets/gcp.json  # khi OCR_ENGINE=google_vision

READINESS_SUBMIT_THRESHOLD=0.9

JWT_SECRET=change-me
JWT_ACCESS_TTL_MINUTES=30
